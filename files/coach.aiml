<?xml version="1.0" encoding="UTF-8"?>
<aiml version="2.0">

<category>
  <pattern>COACH THIS: *</pattern>
  <template>
    <think>
      <set name="mode">coach</set>
      <set name="student_answer"><star/></set>
    </think>
    [AI_COACH_REQUEST]
    mode=coach
    lesson=<get name="lesson"/>
    difficulty=<get name="difficulty"/>
    scenario=<get name="scenario"/>
    answer=<star/>
  </template>
</category>

<category>
  <pattern>ADAPT ME</pattern>
  <template>
    [AI_ADAPT_REQUEST]
    lesson=<get name="lesson"/>
    difficulty=<get name="difficulty"/>
  </template>
</category>

</aiml>