<?xml version="1.0" encoding="UTF-8"?>
<aiml version="2.0">

<category>
  <pattern>PRACTICE</pattern>
  <template>
    <srai>PRACTICE MODE</srai>
  </template>
</category>

<category>
  <pattern>START PRACTICE</pattern>
  <template>
    <srai>PRACTICE MODE</srai>
  </template>
</category>

<category>
  <pattern>PRACTICE MODE</pattern>
  <template>
    <think>
      <set name="mode">practice</set>
      <set name="scenario">refund_issue</set>
    </think>
    Practice scenario:
    A user says, "I want a refund but your system is not working."

    Write how a good assistant should respond.
  </template>
</category>

<category>
  <pattern>*</pattern>
  <that>Practice scenario:*</that>
  <template>
    Good attempt.

    A stronger answer would:
    - acknowledge the issue
    - show empathy
    - ask for the next useful detail

    Example:
    I’m sorry you’re facing this issue. Please share your order ID so I can help with your refund.

    Type NEXT PRACTICE.
  </template>
</category>

<category>
  <pattern>NEXT PRACTICE</pattern>
  <template>
    <think><set name="scenario">login_problem</set></think>
    Practice scenario:
    A user says, "I can’t log into my account."

    Write the assistant response.
  </template>
</category>

</aiml>