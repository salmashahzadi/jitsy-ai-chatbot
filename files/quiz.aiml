<?xml version="1.0" encoding="UTF-8"?>
<aiml>

<category>
  <pattern>QUIZ ME</pattern>
  <template>
    <think><set name="quiz">1</set></think>

    Question:
    What is persona?

    A. Code  
    B. Personality  
    C. Database  

    Say ANSWER A, B or C.
  </template>
</category>

<category>
  <pattern>ANSWER B</pattern>
  <template>
    <condition name="quiz">
      <li value="1">
        Correct ✅ Persona defines personality.
        <think><set name="quiz">2</set></think>
      </li>
    </condition>
  </template>
</category>

<category>
  <pattern>ANSWER A</pattern>
  <template>
    Incorrect ❌ Correct is B.
  </template>
</category>

<category>
  <pattern>ANSWER C</pattern>
  <template>
    Incorrect ❌ Correct is B.
  </template>
</category>

</aiml>